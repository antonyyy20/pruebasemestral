# General configuration
PROJECT_NAME="Quickvnt API"
API_V1_STR="/api/v1"

# Supabase credentials
# Replace <your-project> with your Supabase project ID
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-from-dashboard"

# Supabase PostgreSQL database URL (asyncpg asynchronous connector)
# Replace with your Supabase host, password (LhMwLxlUd7UeDcTK), and port (6543 or 5432)
DATABASE_URL="postgresql+asyncpg://postgres:LhMwLxlUd7UeDcTK@db.your-project-id.supabase.co:6543/postgres"

# Internal secret key to sign and verify QR Codes (HMAC-SHA256)
QR_JWT_SECRET="generate-a-long-random-string-for-security"
